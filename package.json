{
  "name": "@creatorcrawl/mcp",
  "version": "0.2.0",
  "description": "Official MCP server for CreatorCrawl. 60+ tools for TikTok, Instagram, YouTube, LinkedIn, Twitter/X, and Reddit. Stdio MCP server that proxies to the CreatorCrawl hosted API.",
  "license": "MIT",
  "author": "CreatorCrawl <support@creatorcrawl.com>",
  "homepage": "https://creatorcrawl.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatorcrawl/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/creatorcrawl/mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "creatorcrawl",
    "social-media-api",
    "tiktok",
    "instagram",
    "youtube",
    "linkedin",
    "twitter",
    "reddit",
    "scraper",
    "claude",
    "cursor"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "creatorcrawl-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
